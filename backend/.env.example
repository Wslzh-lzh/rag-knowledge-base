# Database
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag_kb

# Cache
REDIS_URL=redis://localhost:6379/0

# Vector Search
QDRANT_URL=http://localhost:6333

# Full-text Search
OPENSEARCH_URL=http://localhost:9200

# Object Storage (MinIO compatible)
OBJECT_STORAGE_URL=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minio
OBJECT_STORAGE_SECRET_KEY=minio12345
OBJECT_STORAGE_BUCKET=rag-documents
OBJECT_STORAGE_USE_PATH_STYLE=true

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=work/storage

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Bootstrap Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# LLM
DEFAULT_LLM_PROVIDER=echo
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-3.5-turbo

# Embedding
DEFAULT_EMBEDDING_MODEL=BGE-M3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# App
ENVIRONMENT=local
